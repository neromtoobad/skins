{
  "name": "skins-mcp",
  "version": "0.3.1",
  "description": "Model Context Protocol server that converts a natural-language vibe, scraped URL, base64 image, or motionsites.ai design spec into a complete React + Tailwind + Framer Motion design system.",
  "main": "dist/src/index.js",
  "bin": {
    "skins-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "start": "ts-node src/index.ts",
    "serve": "ts-node src/server.ts",
    "serve:prod": "node dist/src/server.js",
    "demo": "ts-node demo.ts",
    "build": "tsc",
    "verify": "tsc --noEmit && node scripts/verify-output.mjs",
    "verify:browser": "node scripts/browser-verify.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design-system",
    "tailwind",
    "framer-motion",
    "react"
  ],
  "author": "skins-mcp contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "express": "^5.1.0",
    "framer-motion": "^11.0.0",
    "openai": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
